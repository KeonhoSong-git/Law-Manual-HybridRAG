# 실제 값은 .env 에 두세요(.gitignore 로 제외). 시크릿은 환경변수로만 주입.

# --- LLM (OpenAI 호환): 답변 생성 + 인용 종류분류 ---
API_KEY=your-llm-api-key
LLM_MODEL=your-model-name
LLM_API_BASE=http://YOUR_LLM_HOST:PORT/v1

# --- 임베딩 (BGE-M3, 1024-dim): 질문 임베딩(질의 시) ---
EMBEDDING_API_BASE=http://YOUR_EMBEDDING_HOST:PORT
EMBEDDING_API_KEY=your-embedding-api-key
# (선택) 2번째 임베딩 엔드포인트 — 같은 BGE-M3. 코퍼스 재임베딩을 두 서버로 병렬 분산.
#   native 서버는 /embeddings, vLLM 호환 서버는 /v1/embeddings(+model 필드)를 자동 사용.
# EMBEDDING_API_BASE_2=http://YOUR_SECOND_EMBEDDING_HOST:PORT
# EMBEDDING_MODEL_2=/models/bge-m3
# EMBEDDING_API_KEY_2=your-second-key   # 생략 시 EMBEDDING_API_KEY 재사용

# --- 데이터 수집: 국가법령정보센터 OPEN API ---
# open.law.go.kr 에서 OC 발급 + 호출 기기 IP/도메인 등록 후 사용
LAW_OC=your-law-go-kr-oc

# --- 데모 데이터 경로(컨테이너 기준, docker-compose 가 설정) ---
# KG_TTL=/data/kg.ttl
# VECTORS_PATH=/data/vectors.jsonl
# TOP_K=6
